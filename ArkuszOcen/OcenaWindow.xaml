<Window x:Class="ArkuszOcen.OcenaWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:local="clr-namespace:ArkuszOcen"
mc:Ignorable="d"
Title="Ocena" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
Loaded="Window_Loaded">
    <StackPanel Margin="20" >
        <UniformGrid Columns="2" VerticalAlignment="Top">
            <Label Content="_Przedmiot" Margin="5" />
            <TextBox x:Name="tbPrzedmiot" Margin="5" />
            <Label Content="_Wartość" Margin="5" />
            <TextBox x:Name="tbWartość" Margin="5" />
        </UniformGrid>
        <UniformGrid Columns="2" Margin="0,20,0,0">
            <Button Content="_Zatwierdź" IsDefault="True" Click="Zatwierdź_Click" Margin="5"/>
            <Button Content="_Anuluj" Margin="5" Click="Anuluj_Click" IsDefault="True"/>
        </UniformGrid>
    </StackPanel>
</Window>